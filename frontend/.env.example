# Tai Live — Environment Variables
# Copy to .env.local and fill in your values

# ========== Enoki (Required for sponsored transactions) ==========
NEXT_PUBLIC_ENOKI_API_KEY=           # Enoki public API key
ENOKI_PRIVATE_API_KEY=               # Enoki private API key (server-side only)

# ========== Google OAuth (Required for zkLogin) ==========
NEXT_PUBLIC_GOOGLE_CLIENT_ID=        # Google OAuth 2.0 client ID

# ========== Sui Package (Required) ==========
NEXT_PUBLIC_TAI_PACKAGE_ID=          # Deployed Tai package ID (all modules)

# ========== Shared Object IDs (Required) ==========
NEXT_PUBLIC_POINTS_REGISTRY_ID=      # PointsRegistry shared object ID
NEXT_PUBLIC_REPUTATION_REGISTRY_ID=  # ReputationRegistry shared object ID
NEXT_PUBLIC_TREASURY_ID=             # payment_distribution Treasury shared object ID
NEXT_PUBLIC_SESSION_REGISTRY_ID=     # viewer_session SessionRegistry shared object ID
NEXT_PUBLIC_STREAM_REGISTRY_ID=      # live_stream StreamRegistry shared object ID

# ========== Upgrade Cap (Keep safe — do not share!) ==========
UPGRADE_CAP_ID=                      # Package upgrade capability object ID
